    <!-- 
  DRONE MODEL — SCALED UP FOR VISIBILITY AT Z=60m
  Replace the entire <model name="drone">...</model> block
  in your .world file with this.

  Changes from original:
    Body:     0.35 x 0.35 x 0.12  →  2.8 x 2.8 x 0.5
    Arms:     radius 0.02, len 0.5 →  radius 0.08, len 4.0
    Rotors:   radius 0.13         →  radius 1.0
    LiDAR:    small cylinder      →  larger cylinder
    Arm poses scaled proportionally
-->

 <model name="drone">
      <pose>0 0 5 0 0 0</pose>

      <link name="base_link">
      	<gravity>false</gravity>
        <inertial>
          <mass>1.5</mass>
          <inertia>
            <ixx>0.0347563</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.0458929</iyy><iyz>0</iyz>
            <izz>0.0977</izz>
          </inertia>
        </inertial>

        <!-- Visual body — large so drone is visible at 60m altitude -->
        <visual name="body_vis">
          <geometry><box><size>2.8 2.8 0.5</size></box></geometry>
          <material>
            <ambient>0.1 0.1 0.1 1</ambient>
            <diffuse>0.2 0.2 0.2 1</diffuse>
          </material>
        </visual>

        <!-- Collision body — KEPT SMALL so LiDAR rays are NOT blocked -->
        <!-- Visual and collision are intentionally different sizes     -->
        <!-- LiDAR min range 3.5m will skip past this 0.35m box        -->
        <collision name="body_col">
          <geometry><box><size>0.35 0.35 0.12</size></box></geometry>
        </collision>

        <!-- Arm Front-Right -->
        <visual name="arm_fr">
          <pose>1.76 -1.76 0 0 0 -0.785</pose>
          <geometry><cylinder><radius>0.08</radius><length>4.0</length></cylinder></geometry>
          <material><ambient>0.3 0.3 0.3 1</ambient><diffuse>0.4 0.4 0.4 1</diffuse></material>
        </visual>

        <!-- Arm Front-Left -->
        <visual name="arm_fl">
          <pose>1.76 1.76 0 0 0 0.785</pose>
          <geometry><cylinder><radius>0.08</radius><length>4.0</length></cylinder></geometry>
          <material><ambient>0.3 0.3 0.3 1</ambient><diffuse>0.4 0.4 0.4 1</diffuse></material>
        </visual>

        <!-- Arm Rear-Right -->
        <visual name="arm_rr">
          <pose>-1.76 -1.76 0 0 0 0.785</pose>
          <geometry><cylinder><radius>0.08</radius><length>4.0</length></cylinder></geometry>
          <material><ambient>0.3 0.3 0.3 1</ambient><diffuse>0.4 0.4 0.4 1</diffuse></material>
        </visual>

        <!-- Arm Rear-Left -->
        <visual name="arm_rl">
          <pose>-1.76 1.76 0 0 0 -0.785</pose>
          <geometry><cylinder><radius>0.08</radius><length>4.0</length></cylinder></geometry>
          <material><ambient>0.3 0.3 0.3 1</ambient><diffuse>0.4 0.4 0.4 1</diffuse></material>
        </visual>

        <!-- Rotor Front-Right — RED -->
        <visual name="rotor_fr">
          <pose>2.48 -2.48 0.2 0 0 0</pose>
          <geometry><cylinder><radius>1.0</radius><length>0.05</length></cylinder></geometry>
          <material><ambient>0.8 0.1 0.1 1</ambient><diffuse>1.0 0.1 0.1 1</diffuse></material>
        </visual>

        <!-- Rotor Front-Left — GREEN -->
        <visual name="rotor_fl">
          <pose>2.48 2.48 0.2 0 0 0</pose>
          <geometry><cylinder><radius>1.0</radius><length>0.05</length></cylinder></geometry>
          <material><ambient>0.1 0.8 0.1 1</ambient><diffuse>0.1 1.0 0.1 1</diffuse></material>
        </visual>

        <!-- Rotor Rear-Right — GREEN -->
        <visual name="rotor_rr">
          <pose>-2.48 -2.48 0.2 0 0 0</pose>
          <geometry><cylinder><radius>1.0</radius><length>0.05</length></cylinder></geometry>
          <material><ambient>0.1 0.8 0.1 1</ambient><diffuse>0.1 1.0 0.1 1</diffuse></material>
        </visual>

        <!-- Rotor Rear-Left — RED -->
        <visual name="rotor_rl">
          <pose>-2.48 2.48 0.2 0 0 0</pose>
          <geometry><cylinder><radius>1.0</radius><length>0.05</length></cylinder></geometry>
          <material><ambient>0.8 0.1 0.1 1</ambient><diffuse>1.0 0.1 0.1 1</diffuse></material>
        </visual>

        <!-- LiDAR body visual -->
        <visual name="lidar_body">
          <pose>0 0 -0.5 0 0 0</pose>
          <geometry><cylinder><radius>0.25</radius><length>0.4</length></cylinder></geometry>
          <material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
        </visual>

        <!-- ======================================================
             LIDAR SENSOR
             - min range 3.5m  → skips past the 0.35m collision box
             - max range 120m  → easily reaches ground from 60m alt
             - visualize false → no blue ray fan in Gazebo GUI
        ====================================================== -->
<sensor name="lidar" type="ray">
  <pose>0 0 -0.12 0 0 0</pose>
  <always_on>true</always_on>
  <update_rate>10</update_rate>
  <visualize>true</visualize>

  <ray>
    <scan>
      <horizontal>
        <samples>720</samples>
        <resolution>1</resolution>
        <min_angle>-3.14159265</min_angle>
        <max_angle>3.14159265</max_angle>
      </horizontal>
      <vertical>
        <samples>16</samples>
        <resolution>1</resolution>
        <min_angle>-0.7853982</min_angle>
        <max_angle>0.1745329</max_angle>
      </vertical>
    </scan>
    <range>
      <min>0.1</min>
      <max>150.0</max>
      <resolution>0.01</resolution>
    </range>
    <noise>
      <type>gaussian</type>
      <mean>0.0</mean>
      <stddev>0.01</stddev>
    </noise>
  </ray>

  <plugin name="gazebo_ros_lidar" filename="libgazebo_ros_ray_sensor.so">
    <ros>
      <remapping>~/out:=/drone/lidar/scan</remapping>
    </ros>
    <output_type>sensor_msgs/LaserScan</output_type>
    <frame_name>base_link</frame_name>
  </plugin>

  <plugin name="gazebo_ros_lidar_pc2" filename="libgazebo_ros_ray_sensor.so">
    <ros>
      <remapping>~/out:=/drone/lidar/points</remapping>
    </ros>
    <output_type>sensor_msgs/PointCloud2</output_type>
    <frame_name>base_link</frame_name>
  </plugin>

</sensor>
<sensor name="imu_sensor" type="imu">
  <always_on>true</always_on>
  <update_rate>100</update_rate>
  <visualize>true</visualize>

  <imu>
    <angular_velocity>
      <x>
        <noise type="gaussian">
          <mean>0.0</mean>
          <stddev>0.0002</stddev>
        </noise>
      </x>
      <y>
        <noise type="gaussian">
          <mean>0.0</mean>
          <stddev>0.0002</stddev>
        </noise>
      </y>
      <z>
        <noise type="gaussian">
          <mean>0.0</mean>
          <stddev>0.0002</stddev>
        </noise>
      </z>
    </angular_velocity>

    <linear_acceleration>
      <x>
        <noise type="gaussian">
          <mean>0.0</mean>
          <stddev>0.017</stddev>
        </noise>
      </x>
      <y>
        <noise type="gaussian">
          <mean>0.0</mean>
          <stddev>0.017</stddev>
        </noise>
      </y>
      <z>
        <noise type="gaussian">
          <mean>0.0</mean>
          <stddev>0.017</stddev>
        </noise>
      </z>
    </linear_acceleration>
  </imu>

  <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
    <ros>
      <remapping>~/out:=/drone/imu</remapping>
    </ros>
    <frame_name>base_link</frame_name>
  </plugin>
</sensor>

      </link>

      <plugin name="drone_waypoint_plugin" filename="libgazebo_ros_planar_move.so">
        <ros>
          <remapping>cmd_vel:=/drone/cmd_vel</remapping>
          <remapping>odom:=/drone/odom</remapping>
        </ros>
        <update_rate>50</update_rate>
        <publish_rate>10</publish_rate>
        <publish_odom>true</publish_odom>
        <publish_odom_tf>true</publish_odom_tf>
        <odometry_frame>odom</odometry_frame>
        <robot_base_frame>base_link</robot_base_frame>
      </plugin>

    </model>
  </world>
</sdf>
